# Copy to .env and set values. Required for: just deploy, just create-market, etc.
# Forge loads .env from this directory (where foundry.toml lives).

# Deployer private key (hex, with or without 0x)
PRIVATE_KEY=0x...

# For set-cre-forwarder and create-market: Sub0 contract address
# SUB0_ADDRESS=0x3b3be6228e251675Bd75b929C4256D940e11C5dC

# Optional: CRE Keystone Forwarder address (set-cre-forwarder). Defaults to Base Sepolia if unset.
# CRE_FORWARDER_ADDRESS=0x82300bd7c3958625581cc2F77bC6464dcEcDF3e5

# Optional: override for deploy script
# USDC_ADDRESS=
# DON_SIGNER_ADDRESS=
# BACKEND_SIGNER_ADDRESS=
