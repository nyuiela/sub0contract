# Sub0 contract – copy to .env and fill values. Never commit .env.

# Required for all deploys
PRIVATE_KEY=0x...

# ---- Sepolia ----
SEPOLIA_RPC_URL=https://rpc.sepolia.org
ETHERSCAN_API_KEY=...
# Optional for Sepolia
USDC_ADDRESS=0x...
CRE_FORWARDER_ADDRESS=0x...

# ---- Tenderly (chain 9998453) ----
TENDERLY_SUB0_RPC_URL=https://virtual.rpc.tenderly.co/your-account/project/public/Subo
TENDERLY_CRE_FORWARDER_ADDRESS=0x...
# USDC on Tenderly: use existing token or deploy mock (just deploy-mock-usdc-tenderly then set address below)
TENDERLY_USDC_ADDRESS=0x8bb2db64840bfddf257487efef884b2fa24e32ea
# Optional: for just verify-tenderly <address>
TENDERLY_VERIFIER_URL=https://virtual.rpc.tenderly.co/your-account/project/public/Subo/verify

# ---- Optional (both networks) ----
DON_SIGNER_ADDRESS=0x...
BACKEND_SIGNER_ADDRESS=0x...
